# Discord application
DISCORD_APPLICATION_ID=000000000000000000
DISCORD_CLIENT_ID=000000000000000000
DISCORD_CLIENT_SECRET=replace_me
DISCORD_BOT_TOKEN=replace_me
DISCORD_PUBLIC_KEY=replace_me
ENABLE_BRIDGE_DISCORD_BOT=false

# Development guild for instant command registration
DISCORD_DEV_GUILD_ID=000000000000000000

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3001
PUBLIC_SERVER_ORIGIN=http://localhost:3001
PUBLIC_CLIENT_ORIGIN=http://localhost:5173
ACTIVITY_BRIDGE_TOKEN=replace_with_shared_dashboard_bridge_token

# Activity client
VITE_DISCORD_CLIENT_ID=000000000000000000
VITE_SERVER_ORIGIN=http://localhost:3001
VITE_WS_ORIGIN=ws://localhost:3001

# OBS WebSocket, OBS Studio 28+ includes obs-websocket by default.
OBS_WEBSOCKET_URL=ws://127.0.0.1:4455
OBS_WEBSOCKET_PASSWORD=replace_me_or_leave_blank_for_local_testing
OBS_SCENE_LIVE=Live
OBS_SCENE_BRB=BRB
OBS_SCENE_ACTIVITY=Activity
OBS_STREAM_KEY_NAME=default

# Twitch API placeholders. The starter can update channel metadata if you add credentials.
TWITCH_CLIENT_ID=replace_me
TWITCH_CLIENT_SECRET=replace_me
TWITCH_BROADCASTER_ID=replace_me
TWITCH_ACCESS_TOKEN=replace_me

# Optional security flags
ALLOW_ACTIVITY_SIDE_CONTROLS=false
ALLOW_STREAM_START_STOP=false
