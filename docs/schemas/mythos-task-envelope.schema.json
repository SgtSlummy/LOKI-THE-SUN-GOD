{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mythos Task Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "sector",
    "swarm",
    "priority",
    "status",
    "objective",
    "inputs",
    "outputs",
    "memory_targets",
    "repo_paths",
    "docs_paths",
    "dependencies",
    "acceptance_criteria",
    "rollback_plan",
    "grade",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_task_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "sector": {
      "enum": [
        "discord",
        "agi",
        "music",
        "knowledge",
        "memory",
        "router",
        "plugins",
        "database",
        "deployment",
        "qc"
      ]
    },
    "swarm": {
      "enum": [
        "research",
        "github",
        "docs",
        "architecture",
        "coding",
        "testing",
        "qc",
        "deployment",
        "memory",
        "mutation",
        "media",
        "plugin"
      ]
    },
    "priority": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "status": {
      "enum": [
        "queued",
        "running",
        "blocked",
        "complete",
        "failed"
      ]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array"
    },
    "outputs": {
      "type": "array"
    },
    "memory_targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "repo_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "docs_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rollback_plan": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "grade": {
      "type": [
        "object",
        "null"
      ]
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}
