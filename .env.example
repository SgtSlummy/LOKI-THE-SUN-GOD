DISCORD_TOKEN=your-discord-bot-token
# Enable MESSAGE_CONTENT and GUILD_MEMBERS in the Discord Developer Portal for this bot.
# Discord UX policy: natural language is the default. Slash command sync requires
# setting LOKI_NATURAL_LANGUAGE_ONLY=false and LOKI_ENABLE_SLASH_SYNC=true.
LOKI_NATURAL_LANGUAGE_ONLY=true
LOKI_ENABLE_SLASH_SYNC=false
PREFIX=!
OWNER_ID=
TEST_GUILD_ID=

DISCORD_CLIENT_ID=your-discord-application-client-id
DISCORD_CLIENT_SECRET=your-discord-application-client-secret
REDIRECT_URI=http://127.0.0.1:5000/callback
DASHBOARD_PUBLIC_URL=http://127.0.0.1:5000
DASHBOARD_SECRET_KEY=replace-this-with-a-long-random-secret

DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5000
DASHBOARD_DEBUG=false
DATABASE_URL=

# Optional LOKI THE SUN GOD /ask LLM command. OPENAI_BASE_URL may point to OpenAI,
# 9router, Ollama's OpenAI-compatible endpoint, or another compatible router.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LOKI_LLM_MODEL=gpt-5.5
LOKI_LLM_MAX_PROMPT_CHARS=1800
LOKI_LLM_MAX_COMPLETION_TOKENS=500
LOKI_NPC_ENABLED=false
LOKI_NPC_ALLOWED_CHANNEL_IDS=
LOKI_NPC_MEMORY_OPT_OUT_USER_IDS=

LAVALINK_URI=http://127.0.0.1:2333
LAVALINK_PASSWORD=youshallnotpass
LOKI_DEFAULT_EQ_PRESET=Flat
LOKI_DEFAULT_VOLUME=80

ACTIVITY_BRIDGE_URL=http://127.0.0.1:3001
ACTIVITY_BRIDGE_TOKEN=replace_with_shared_dashboard_bridge_token
ACTIVITY_BRIDGE_TIMEOUT_SECONDS=4
ACTIVITY_CLIENT_PUBLIC_URL=http://127.0.0.1:5173
ALLOW_ACTIVITY_SIDE_CONTROLS=false
ALLOW_STREAM_START_STOP=false
OBS_WEBSOCKET_URL=ws://127.0.0.1:4455
OBS_WEBSOCKET_PASSWORD=

LOKI_MCP_ENABLE_WRITES=false
LOKI_CODEX_AGI_ROOT=C:\Codex AGI
LOKI_MEMPALACE_ROOT=
LOKI_MYTHOS_RUN_DIR=.mythos/loki-diva-reprocess

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# LOKI THE SUN GOD channel relay. Keep disabled for local dashboard-only runs.
# If RELAY_ENABLED=true, DATABASE_URL is required so every relay worker shares
# the same send_dedupe table and cannot double-post.
# Set ALLOW_LOCAL_SQLITE_RELAY=true only when this machine should be the only
# live relay worker and you want local SQLite relay without DATABASE_URL.
RELAY_ENABLED=false
ALLOW_LOCAL_SQLITE_RELAY=false
RELAY_GUILD_ID=
RELAY_FRIENDS_ROLE_NAME=Friends
RELAY_TARGET_CHANNEL_IDS=
RELAY_TARGET_CHANNEL_NAMES=
RELAY_IGNORED_SOURCE_CHANNEL_IDS=
RELAY_SENSITIVE_CHANNEL_IDS=

# Wreckingball app output cleanup for the jukebox channel.
WRECKINGBALL_CLEANUP_ENABLED=true
WRECKINGBALL_CLEANUP_CHANNEL_ID=
WRECKINGBALL_CLEANUP_CHANNEL_IDS=
WRECKINGBALL_CLEANUP_AUTHOR_ID=
WRECKINGBALL_CLEANUP_MAX_AGE_SECONDS=180
WRECKINGBALL_CLEANUP_MAX_VISIBLE=2
WRECKINGBALL_CLEANUP_SCAN_LIMIT=50
WRECKINGBALL_CLEANUP_INTERVAL_SECONDS=30
WRECKINGBALL_CLEANUP_MAX_VISIBLE_BY_CHANNEL=
WRECKINGBALL_CLEANUP_MAX_AGE_SECONDS_BY_CHANNEL=
WRECKINGBALL_CLEANUP_SCAN_LIMIT_BY_CHANNEL=

# Managed LOKI THE SUN GOD mirror for the Diva/Wreckingball song-request message.
DIVA_SONG_EMBED_ENABLED=false
DIVA_SONG_EMBED_GUILD_ID=
DIVA_SONG_EMBED_CHANNEL_ID=
DIVA_SONG_EMBED_AUTHOR_ID=
DIVA_SONG_EMBED_SOURCE_MESSAGE_ID=
DIVA_SONG_EMBED_MANAGED_MESSAGE_ID=
DIVA_SONG_EMBED_DASHBOARD_URL=
DIVA_SONG_EMBED_REFRESH_SECONDS=30
DIVA_SONG_EMBED_HISTORY_LIMIT=100

SONG_REQUESTS_PIN_MIRROR_ENABLED=false
SONG_REQUESTS_PIN_MIRROR_GUILD_ID=
SONG_REQUESTS_PIN_MIRROR_SOURCE_CHANNEL_ID=
SONG_REQUESTS_PIN_MIRROR_TARGET_CHANNEL_ID=
SONG_REQUESTS_PIN_MIRROR_MANAGED_MESSAGE_ID=
SONG_REQUESTS_PIN_MIRROR_REFRESH_SECONDS=30
SONG_REQUESTS_PIN_MIRROR_SOURCE_HISTORY_LIMIT=10
SONG_REQUESTS_PIN_MIRROR_TARGET_HISTORY_LIMIT=50
SONG_REQUESTS_PIN_MIRROR_COMMAND_CLEANUP_AGE_SECONDS=60
SONG_REQUESTS_PIN_MIRROR_COMMAND_PREFIXES=/,!,.,?,$,-
